<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/playerBackground"
    android:background="@color/surface_dark">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">
        
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="16dp"
        android:paddingBottom="100dp">

        <!-- Ảnh cover album -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="300dp"
            android:layout_height="300dp"
            app:cardCornerRadius="32dp"
            app:cardElevation="20dp"
            android:layout_marginTop="32dp"
            app:strokeWidth="2dp"
            app:strokeColor="#40FFFFFF">

            <ImageView
                android:id="@+id/imageCover"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/image_cover_player"
                android:scaleType="centerCrop"
                android:src="@drawable/placeholder" />
                
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginTop="24dp">

            <TextView
                android:id="@+id/textSongTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/song_title"
                style="@style/TextAppearance.Modern.Headline"
                android:textSize="28sp"
                android:textColor="@android:color/white"
                android:shadowColor="#80000000"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="4"
                android:gravity="center" />

            <TextView
                android:id="@+id/textArtist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/artist"
                style="@style/TextAppearance.Modern.Title"
                android:textSize="18sp"
                android:textColor="@color/text_hint"
                android:shadowColor="#80000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="2"
                android:gravity="center" />
        </LinearLayout>

        <!-- SeekBar + thời gian -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="24dp">

            <TextView
                android:id="@+id/textCurrentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/duration_player"
                android:textSize="12sp"
                android:textColor="@android:color/darker_gray" />

            <SeekBar
                android:id="@+id/seekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="8dp"
                android:thumb="@drawable/seekbar_thumb"
                android:progressTint="@color/accent_pink"
                android:progressBackgroundTint="#40FFFFFF"
                android:thumbTint="@color/accent_pink" />

            <TextView
                android:id="@+id/textTotalTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/duration_song_player"
                android:textSize="12sp"
                android:textColor="@android:color/darker_gray" />
        </LinearLayout>

        <!-- Nút điều khiển chính -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="24dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="32dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/surface_glass">
                
                <ImageButton
                    android:id="@+id/btnPrevious"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/ripple_effect"
                    android:src="@drawable/ic_skip_previous"
                    app:tint="@android:color/white" />
                    
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="48dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="@android:color/white"
                android:layout_marginHorizontal="24dp">

                <ImageButton
                    android:id="@+id/btnPlayPause"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:background="@drawable/ripple_effect"
                    android:src="@drawable/ic_play"
                    app:tint="@android:color/black"/>
                    
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="32dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/surface_glass">
                
                <ImageButton
                    android:id="@+id/btnNext"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/ripple_effect"
                    android:src="@drawable/ic_skip_next"
                    app:tint="@android:color/white" />
                    
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Các nút phụ (shuffle, repeat, favorite) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <ImageButton
                android:id="@+id/btnShuffle"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_shuffle"
                android:scaleType="centerInside" />

            <ImageButton
                android:id="@+id/btnRepeat"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_repeat"
                android:scaleType="centerInside" />

            <ImageButton
                android:id="@+id/btnFavorite"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_favorite"
                android:scaleType="centerInside" />

            <ImageButton
                android:id="@+id/btnLyrics"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_lyrics"
                android:scaleType="centerInside"
                app:tint="@android:color/white" />

            <ImageButton
                android:id="@+id/btnAddToPlaylist"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:src="@android:drawable/ic_input_add"
                android:scaleType="centerInside"
                app:tint="@android:color/white" />
        </LinearLayout>


    </LinearLayout>
    
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
