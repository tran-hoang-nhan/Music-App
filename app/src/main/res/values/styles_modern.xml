<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Modern Text Styles -->
    <style name="TextAppearance.Modern.Headline" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:fontFamily">@font/mulish_bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>
    
    <style name="TextAppearance.Modern.Title" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:fontFamily">@font/mulish_medium</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.Modern.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">@font/mulish_regular</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>
    
    <!-- Modern Card Style -->
    <style name="CardView.Modern">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">8dp</item>
        <item name="cardBackgroundColor">@android:color/white</item>
        <item name="android:layout_margin">12dp</item>
    </style>
    
    <!-- Modern Button Style -->
    <style name="Button.Modern" parent="Widget.Material3.Button">
        <item name="android:background">@drawable/gradient_primary</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:fontFamily">@font/mulish_medium</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:elevation">4dp</item>
        <item name="cornerRadius">24dp</item>
    </style>
</resources>