<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@+id/navigation_dashboard">

    <fragment
        android:id="@+id/navigation_dashboard"
        android:name="com.example.musicapp.ui.dashboard.DashboardFragment"
        android:label="Trang Chủ"
        tools:layout="@layout/fragment_dashboard" />
    <fragment
        android:id="@+id/navigation_discover"
        android:name="com.example.musicapp.ui.discover.DiscoverFragment"
        android:label="Khám Phá"
        tools:layout="@layout/fragment_discover" />
    <fragment
        android:id="@+id/navigation_library"
        android:name="com.example.musicapp.ui.library.LibraryFragment"
        android:label="Thư Viện"
        tools:layout="@layout/fragment_library" />
    <fragment
        android:id="@+id/navigation_profile"
        android:name="com.example.musicapp.ui.profile.ProfileFragment"
        android:label="Cá Nhân"
        tools:layout="@layout/fragment_profile" >
        <!-- Khi user chưa đăng nhập, chuyển sang Login -->
        <action
            android:id="@+id/action_profile_to_login"
            app:destination="@id/navigation_login" />
        <!-- Profile → Insights -->
        <action
            android:id="@+id/action_profile_to_insights"
            app:destination="@id/navigation_insights" />
    </fragment>

    <fragment
        android:id="@+id/navigation_login"
        android:name="com.example.musicapp.ui.profile.LoginFragment"
        android:label="Đăng Nhập"
        tools:layout="@layout/fragment_login" >
        <!-- Login → Register -->
        <action
            android:id="@+id/action_login_to_register"
            app:destination="@id/navigation_register" />
    </fragment>

    <fragment
        android:id="@+id/navigation_register"
        android:name="com.example.musicapp.ui.profile.RegisterFragment"
        android:label="Đăng Ký"
        tools:layout="@layout/fragment_register" >
        <!-- Register → Login (đã có tài khoản) -->
        <action
            android:id="@+id/action_register_to_login"
            app:destination="@id/navigation_login" />
    </fragment>

    <fragment
        android:id="@+id/navigation_artist_detail"
        android:name="com.example.musicapp.ui.artist.ArtistFragment"
        android:label="Artist Detail"
        tools:layout="@layout/fragment_artist_detail" >
        <argument
            android:name="artistId"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/navigation_album_detail"
        android:name="com.example.musicapp.ui.album.AlbumFragment"
        android:label="Album Detail"
        tools:layout="@layout/fragment_album_detail" >
        <argument
            android:name="albumId"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/navigation_search"
        android:name="com.example.musicapp.ui.search.SearchFragment"
        android:label="Tìm kiếm"
        tools:layout="@layout/fragment_search">
        <argument
            android:name="query"
            app:argType="string"
            app:nullable="true" />
    </fragment>

    <fragment
        android:id="@+id/navigation_genre_detail"
        android:name="com.example.musicapp.ui.discover.GenreDetailFragment"
        android:label="Nhạc theo thể loại"
        tools:layout="@layout/fragment_genre_detail" >
        <!-- Khi user chưa đăng nhập, chuyển sang Login -->
        <action
            android:id="@+id/action_profile_to_login"
            app:destination="@id/navigation_login" />
    </fragment>

    <fragment
        android:id="@+id/navigation_music_player"
        android:name="com.example.musicapp.ui.musicplayerfull.MusicPlayerFragment"
        android:label="Music Player Full"
        tools:layout="@layout/fragment_music_player_full">
        <argument
            android:name="songId"
            app:argType="string"
            app:nullable="true"/>
    </fragment>

    <fragment
        android:id="@+id/navigation_playlist_detail"
        android:name="com.example.musicapp.ui.playlist.PlaylistDetailFragment"
        android:label="Playlist Detail"
        tools:layout="@layout/fragment_playlist_detail">
        <argument
            android:name="playlist_id"
            app:argType="string" />
        <argument
            android:name="playlist_name"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/navigation_user_playlist_detail"
        android:name="com.example.musicapp.ui.library.UserPlaylistDetailFragment"
        android:label="User Playlist Detail"
        tools:layout="@layout/fragment_playlist_detail">
        <argument
            android:name="playlist_id"
            app:argType="string" />
        <argument
            android:name="playlist_name"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/navigation_insights"
        android:name="com.example.musicapp.ui.insights.InsightsFragment"
        android:label="Thống kê cá nhân"
        tools:layout="@layout/fragment_insights" />

    <fragment
        android:id="@+id/navigation_favorites_playlist"
        android:name="com.example.musicapp.ui.library.FavoritesPlaylistFragment"
        android:label="Bài hát yêu thích"
        tools:layout="@layout/fragment_playlist_detail" />

</navigation>